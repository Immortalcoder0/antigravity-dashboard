{
  "name": "antigravity-dashboard",
  "version": "0.2.0",
  "description": "Real-time monitoring dashboard for Google Cloud accounts using the Antigravity OAuth flow. Track API quotas, usage limits, and reset times with Claude/OpenAI compatible API proxy.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NoeFabris/antigravity-dashboard.git"
  },
  "homepage": "https://github.com/NoeFabris/antigravity-dashboard#readme",
  "bugs": {
    "url": "https://github.com/NoeFabris/antigravity-dashboard/issues"
  },
  "keywords": [
    "antigravity",
    "opencode",
    "google-cloud",
    "quota-monitoring",
    "claude",
    "gemini",
    "api-proxy",
    "oauth",
    "dashboard"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "electron/main.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm --filter=./apps/* run build",
    "dev": "pnpm --filter=./apps/* run dev",
    "start": "pnpm --filter=@antigravity/backend start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "oxlint": "^1.39.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
